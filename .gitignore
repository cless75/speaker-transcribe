# ─── Secrets — NEVER commit ───────────────────────────────
*.local.json
credentials*.json
**/token.json
**/*.env
.env

# ─── Biometric data — voiceprints (personal data) ─────────
**/_voiceprints/
**/Speakers/
*voiceprint-profiles.json
*-voiceprint-cache.json

# ─── User media & transcripts ─────────────────────────────
*.m4a
*.mp4
*.mov
*.wav
*.mp3
*.webm
*.mkv
*.m4v
*.avi
*.oga
*-transcript.md
*-transcript.txt
*-segments.*
*-raw.json
*-run-meta.json
*-asr-*.json

# ─── Slide frames — captured screenshots + OCR text are content, not code ──
**/frames/
*-slides.json

# ─── Run logs ─────────────────────────────────────────────
logs/

# ─── Python / virtualenv ──────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# ─── Models & caches ──────────────────────────────────────
*.bin
models/
.cache/

# ─── OS / editor ──────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/

# Node diagnostics reports (written to Hub, but guard against stray local copies)
801-diag-*.txt

# Config backups made by update-node.ps1 -SyncConfig
*.bak
